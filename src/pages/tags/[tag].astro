---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import data from "../../data/repos.json";
import RepoCard from "../../components/RepoCard.astro";
import { CardGrid } from "@astrojs/starlight/components";

export async function getStaticPaths() {
	let allRepoTopics = data.flatMap((repoObj) => {
		return repoObj.topics;
	});

	const uniqueTopicsList = new Set(allRepoTopics);

	let staticPathParamsList = [...uniqueTopicsList].map((topic) => {
		return {
			params: {
				tag: topic,
			},
			props: {
				dataList: data,
				filteredData: data.filter((repoObj: any) => repoObj.topics.includes(topic))
			},

		};
	});



	return staticPathParamsList;
}

const { tag } = Astro.params;
const { dataList, filteredData } = Astro.props;



---

<StarlightPage frontmatter={{ title: `Repos tagged with "${tag}"` }} >
	<p>All repos tagged with {tag}:</p>
	
	<CardGrid>
		{filteredData.map((dataObj: any) => <RepoCard {...dataObj} />)}

	</CardGrid>
</StarlightPage>

