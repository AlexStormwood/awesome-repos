---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";

import RepoCard from "../../components/RepoCard.astro";
import { CardGrid } from "@astrojs/starlight/components";
import { loadAllRepoData } from "../../utils/reposDataManipulator";
import listData from "../../../data/lists.json" with {type:"json"};


export async function getStaticPaths() {

	let data = await loadAllRepoData();

	let allRepoLists = data.flatMap((repoObj) => {
		return repoObj.lists;
	});

	const uniqueListsList = new Set(allRepoLists);

	let staticPathParamsList = [...uniqueListsList].map((list) => {
		return {
			params: {
				list: list,
			},
			props: {
				dataList: data,
				filteredData: data.filter((repoObj: any) => repoObj.lists.includes(list))
			},

		};
	});



	return staticPathParamsList;
}

const { list } = Astro.params;
const { dataList, filteredData } = Astro.props;

const listName = listData.find((listObj) => {
	return listObj.id == list
})?.name || "List"
console.log("List name: " + listName);

---

<StarlightPage frontmatter={{ title: `${listName}` }} >
	<p>All repos tagged with list: {listName}:</p>
	
	<CardGrid>
		{filteredData.map((dataObj: any) => <RepoCard {...dataObj} />)}

	</CardGrid>
</StarlightPage>
